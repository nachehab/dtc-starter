{
  "name": "dtc-starter-monorepo",
  "private": false,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend:seed": "turbo seed --filter=@dtc/backend",
    "backend:dev": "turbo dev --filter=@dtc/backend",
    "storefront:dev": "turbo dev --filter=@dtc/storefront",
    "docker:up": "docker compose up -d --build",
    "docker:dev": "docker compose -f docker-compose.yaml -f docker-compose.dev.yaml --profile dev up",
    "docker:logs": "docker compose logs -f",
    "docker:down": "docker compose down",
    "fix-image-urls": "node scripts/run-fix-image-urls.js"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5"
    }
  },
  "devDependencies": {
    "turbo": "^2.0.14",
    "prettier": "^3.2.5"
  }
}
