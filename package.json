{
  "name": "dtc-starter-monorepo",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "prebuild": "node scripts/check-env-files.js && node scripts/check-no-localhost.js",
    "build": "turbo build",
    "postbuild": "node scripts/check-public-urls.js",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend:seed": "turbo run seed --filter=@dtc/backend",
    "backend:predeploy": "turbo run predeploy --filter=@dtc/backend",
    "healthcheck": "node scripts/check-medusa-health.js",
    "check:medusa-build-output": "node scripts/check-medusa-build-output.js",
    "check:versions": "node scripts/check-runtime-versions.js",
    "outdated": "pnpm outdated -r",
    "docker:up": "docker compose up -d --build",
    "docker:logs": "docker compose logs -f",
    "docker:down": "docker compose down",
    "fix-image-urls": "node scripts/run-fix-image-urls.js",
    "check:public-urls": "node scripts/check-public-urls.js",
    "check-no-localhost": "node scripts/check-no-localhost.js",
    "check-env": "node scripts/check-env-files.js"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "22.19.0",
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5",
      "zod": "4.2.0"
    }
  },
  "devDependencies": {
    "turbo": "^2.0.14",
    "prettier": "^3.2.5"
  }
}
