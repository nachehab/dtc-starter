{
  "name": "@dtc/backend",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "dev": "medusa develop --host 0.0.0.0",
    "build": "medusa build",
    "predeploy": "medusa db:migrate",
    "start": "medusa start",
    "seed": "medusa exec ./src/migration-scripts/initial-data-seed.ts",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "email:test": "medusa exec ./src/scripts/send-test-email.ts"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.14.0",
    "@medusajs/admin-shared": "2.14.0",
    "@medusajs/caching": "2.14.0",
    "@medusajs/caching-redis": "2.14.0",
    "@medusajs/cli": "2.14.0",
    "@medusajs/dashboard": "2.14.0",
    "@medusajs/draft-order": "2.14.0",
    "@medusajs/event-bus-redis": "2.14.0",
    "@medusajs/framework": "2.14.0",
    "@medusajs/locking-redis": "2.14.0",
    "@medusajs/medusa": "2.14.0",
    "@medusajs/ui": "4.1.7",
    "@medusajs/workflow-engine-redis": "2.14.0",
    "@paypal/paypal-server-sdk": "^2.3.0",
    "@tanstack/react-query": "5.64.2",
    "nodemailer": "^8.0.7",
    "react-i18next": "13.5.0",
    "react-router-dom": "6.30.3",
    "zod": "4.2.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.14.0",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
