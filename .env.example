# Backend/admin public URL. Keep these equal.
PUBLIC_BACKEND_URL=https://your-domain
PUBLIC_ASSET_BASE_URL=https://your-domain
MEDUSA_BACKEND_URL=https://your-domain
MEDUSA_ADMIN_BACKEND_URL=https://your-domain

# Storefront public URLs.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://your-domain
NEXT_PUBLIC_ASSET_BASE_URL=https://your-domain
NEXT_PUBLIC_BASE_URL=https://your-storefront-domain

# Backend service connections.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/medusa-store
REDIS_URL=redis://redis:6379
CACHE_REDIS_URL=redis://redis:6379
LOCKING_REDIS_URL=redis://redis:6379

# Backend CORS origins.
STORE_CORS=https://your-storefront-domain,https://your-domain
ADMIN_CORS=https://your-domain
AUTH_CORS=https://your-domain

# Backend auth and cookie settings.
JWT_SECRET=
COOKIE_SECRET=
COOKIE_SAME_SITE=none
COOKIE_SECURE=true
TRUST_PROXY=1
ADMIN_SESSION_COOKIE_DEBUG=false

# Backend app settings.
DB_NAME=medusa-backend
MEDUSA_ADMIN_ONBOARDING_TYPE=default
DISABLE_MEDUSA_ADMIN=false
MEDUSA_WORKER_MODE=server
PORT=9000

# PayPal backend provider settings.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_API_BASE_URL=
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_AUTO_CAPTURE=false

# Backend email settings.
EMAIL_PROVIDER=local
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SITE_PUBLIC_URL=https://your-storefront-domain
ADMIN_PUBLIC_URL=https://your-domain
CONTACT_TO_EMAIL=
EMAIL_ENABLED=false

# Optional seed data image source.
SEED_IMAGE_BASE_URL=

# Storefront public keys and defaults.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_DEFAULT_REGION=ca
NEXT_PUBLIC_STRIPE_KEY=
NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_VERCEL_URL=

# Optional image hosts.
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=
